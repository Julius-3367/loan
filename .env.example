# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database
# Fill in DB_NAME once you have chosen your database name
DB_NAME=
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Security (set both to True in production)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# =============================================================
# ODOO INTEGRATION (fill in when Odoo instance is live)
# =============================================================
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_odoo_database_name
ODOO_USERNAME=api_integration_user@albacapital.co.ke
ODOO_API_KEY=your_odoo_api_key_here

# Webhook secret — shared secret for verifying Odoo → Django webhooks
ODOO_WEBHOOK_SECRET=generate_a_strong_random_secret_here

# Optional: Odoo JSON-RPC timeout (seconds)
ODOO_TIMEOUT=30
