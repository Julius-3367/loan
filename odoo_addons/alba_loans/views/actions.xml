<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        
        <record id="action_alba_customer" model="ir.actions.act_window">
            <field name="name">Customers</field>
            <field name="res_model">alba.customer</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No customers registered yet.
                </p>
                <p>
                    Customers are created when they register on the Django portal
                    or when you create them manually here.
                </p>
            </field>
        </record>

        
        <record id="action_alba_loan_product" model="ir.actions.act_window">
            <field name="name">Loan Products</field>
            <field name="res_model">alba.loan.product</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No loan products configured yet.
                </p>
                <p>
                    Create your first loan product to start accepting
                    loan applications. Configure interest rates, fee
                    structures, tenure limits and accounting accounts here.
                </p>
            </field>
        </record>

        
        <record id="action_alba_loan_application" model="ir.actions.act_window">
            <field name="name">Loan Applications</field>
            <field name="res_model">alba.loan.application</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'search_default_in_progress': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No loan applications yet.
                </p>
                <p>
                    Loan applications submitted through the customer portal will
                    appear here for review, credit analysis, approval and
                    disbursement.
                </p>
            </field>
        </record>

        <record id="action_alba_loan_application_all" model="ir.actions.act_window">
            <field name="name">All Applications</field>
            <field name="res_model">alba.loan.application</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="context">{}</field>
        </record>

        
        <record id="action_alba_loan_list" model="ir.actions.act_window">
            <field name="name">Active Loans</field>
            <field name="res_model">alba.loan</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No loans disbursed yet.
                </p>
                <p>
                    Loans are created automatically when a Loan Application
                    is disbursed using the Disbursement Wizard.
                </p>
            </field>
        </record>

        <record id="action_alba_loan_all" model="ir.actions.act_window">
            <field name="name">All Loans</field>
            <field name="res_model">alba.loan</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

        
        <record id="action_alba_loan_repayment" model="ir.actions.act_window">
            <field name="name">Repayments</field>
            <field name="res_model">alba.loan.repayment</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No repayments posted yet.
                </p>
                <p>
                    Repayments can be posted manually from a loan form or
                    automatically when an M-Pesa transaction is reconciled.
                </p>
            </field>
        </record>

        
        <record id="action_alba_repayment_schedule" model="ir.actions.act_window">
            <field name="name">Repayment Schedules</field>
            <field name="res_model">alba.repayment.schedule</field>
            <field name="view_mode">list</field>
            <field name="context">{'search_default_overdue': 1}</field>
        </record>

        
        <record id="action_alba_mpesa_config" model="ir.actions.act_window">
            <field name="name">M-Pesa Configurations</field>
            <field name="res_model">alba.mpesa.config</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No M-Pesa configurations yet.
                </p>
                <p>
                    Configure Daraja API credentials here to enable STK Push,
                    C2B and B2C M-Pesa integrations.
                </p>
            </field>
        </record>

        
        <record id="action_alba_mpesa_transaction" model="ir.actions.act_window">
            <field name="name">M-Pesa Transactions</field>
            <field name="res_model">alba.mpesa.transaction</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No M-Pesa transactions yet.
                </p>
                <p>
                    All STK Push, C2B and B2C transactions will appear here
                    for monitoring and reconciliation.
                </p>
            </field>
        </record>

        <record id="action_alba_mpesa_transaction_pending" model="ir.actions.act_window">
            <field name="name">M-Pesa — Pending</field>
            <field name="res_model">alba.mpesa.transaction</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('status','=','pending')]</field>
            <field name="context">{'search_default_pending': 1}</field>
        </record>

        <record id="action_alba_mpesa_transaction_needs_attention" model="ir.actions.act_window">
            <field name="name">M-Pesa — Needs Attention</field>
            <field name="res_model">alba.mpesa.transaction</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('needs_attention','=',True)]</field>
            <field name="context">{'search_default_needs_attention': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No unreconciled transactions — great work!
                </p>
            </field>
        </record>

        <!-- Collections -->
        <record id="action_alba_collection_stage" model="ir.actions.act_window">
            <field name="name">Collection Stages</field>
            <field name="res_model">alba.loan.collection.stage</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No collection stages configured yet.</p>
                <p>Define escalation buckets (1–30, 31–60, 61–90, 90+ days) to automate the collections workflow.</p>
            </field>
        </record>

        <record id="action_alba_collection_log" model="ir.actions.act_window">
            <field name="name">Collection Activities</field>
            <field name="res_model">alba.loan.collection.log</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No collection activities logged yet.</p>
            </field>
        </record>

        <record id="action_alba_collection_log_followup" model="ir.actions.act_window">
            <field name="name">Follow-ups Due</field>
            <field name="res_model">alba.loan.collection.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('follow_up_required','=',True),('follow_up_date','&lt;=', context_today().strftime('%Y-%m-%d'))]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No follow-ups due — great work!</p>
            </field>
        </record>

        <!-- Loan Rules -->
        <record id="action_alba_loan_restructure" model="ir.actions.act_window">
            <field name="name">Loan Restructures</field>
            <field name="res_model">alba.loan.restructure</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No restructure requests yet.</p>
                <p>Restructures modify a loan's principal, interest rate and tenure. A 3% restructure fee applies.</p>
            </field>
        </record>

        <record id="action_alba_loan_restructure_pending" model="ir.actions.act_window">
            <field name="name">Pending Restructures</field>
            <field name="res_model">alba.loan.restructure</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state','=','pending')]</field>
        </record>

        <record id="action_alba_loan_reschedule" model="ir.actions.act_window">
            <field name="name">Loan Reschedules</field>
            <field name="res_model">alba.loan.reschedule</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No reschedule requests yet.</p>
                <p>Reschedules allow individual payment dates to be moved without changing the loan terms.</p>
            </field>
        </record>

        <record id="action_alba_loan_early_settlement" model="ir.actions.act_window">
            <field name="name">Early Settlements</field>
            <field name="res_model">alba.loan.early.settlement</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No early settlement quotes yet.</p>
                <p>Generate a settlement quote for customers who wish to pay off their loan before maturity.</p>
            </field>
        </record>

        <record id="action_alba_loan_fee" model="ir.actions.act_window">
            <field name="name">Loan Fees</field>
            <field name="res_model">alba.loan.fee</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No additional loan fees yet.</p>
            </field>
        </record>

        <!-- Approval Workflow Configuration -->
        <record id="action_alba_approval_limit" model="ir.actions.act_window">
            <field name="name">Approval Limits</field>
            <field name="res_model">alba.approval.limit</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No approval limits configured yet.</p>
                <p>Define which role can approve transactions at which amount thresholds.</p>
            </field>
        </record>

        <record id="action_alba_workflow_rule" model="ir.actions.act_window">
            <field name="name">Workflow Rules</field>
            <field name="res_model">alba.workflow.rule</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No workflow rules configured yet.</p>
            </field>
        </record>

        <record id="action_alba_segregation_of_duties" model="ir.actions.act_window">
            <field name="name">Segregation of Duties</field>
            <field name="res_model">alba.segregation.of.duties</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No SoD rules configured yet.</p>
                <p>Configure maker-checker controls to prevent the same user from both creating and approving transactions.</p>
            </field>
        </record>

    </data>
</odoo>